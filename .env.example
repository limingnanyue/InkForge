# ============================================================
# InkForge 墨铸 环境变量
# 复制为 .env 后按需修改；前端「模型中心」也可在线配置 API Key
# ============================================================

# ---------- 服务 ----------
# HTTP 端口（本地 dev 与 Docker 都用这个）
PORT=3001

# ---------- 数据存储 ----------
# 数据目录：本地默认 ./api/data，Docker / 服务器部署建议挂载独立卷
# INKFORGE_DATA_DIR=/data
# INKFORGE_DB_PATH=/data/inkforge.db

# ---------- 守护进程 ----------
# 是否在 HTTP 服务内嵌守护进程：
#   true  → 本地一体化（推荐本地开发与小规模部署）
#   false → 仅运行 HTTP 服务，需另行 `pnpm start:worker` 启动独立 worker（高并发推荐）
INKFORGE_EMBED_WORKER=true

# ---------- AI 提供商（可选，留空则在「模型中心」在线配置）----------
# OpenAI 兼容（同时覆盖 DeepSeek / 通义千问 / 自定义 OpenAI 兼容端点）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic 原生协议
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# DeepSeek
# DEEPSEEK_API_KEY=

# 阿里通义千问
# DASHSCOPE_API_KEY=

# ---------- 时区（影响日志与导出文件名）----------
TZ=Asia/Shanghai
